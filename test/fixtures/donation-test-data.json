  "scenarios": {
    "one_time_donation_small": {
      "name": "One-Time Donation - $10",
      "description": "Basic one-time donation with all required fields",
      "endpoint": "POST /api/mosques/al-noor-houston/donations/create-intent",
      "request": {
        "amount": 1000,
        "donation_type": "one_time",
        "purpose": "general",
        "donor_name": "John Smith",
        "donor_email": "john.smith@example.com",
        "donor_phone": "+14155552671",
        "donor_message": "May Allah bless this community",
        "is_anonymous": false
      },
      "expected_response": {
        "success": true,
        "data": {
          "donation_id": "uuid-here",
          "client_secret": "pi_test_xxx_secret_xxx",
          "type": "payment_intent",
          "amount": 1000,
          "amount_display": "$10.00",
          "payment_intent_id": "pi_xxx",
          "stripe_account": "acct_alNoorHouston",
          "created_at": "2026-03-15T12:00:00Z"
        }
      },
      "next_step": "Use client_secret with Stripe iOS/Android SDK to complete payment"
    },
    "one_time_donation_large": {
      "name": "One-Time Donation - $500 (Building Fund)",
      "description": "Large one-time donation for specific purpose",
      "endpoint": "POST /api/mosques/al-noor-houston/donations/create-intent",
      "request": {
        "amount": 50000,
        "donation_type": "one_time",
        "purpose": "building_fund",
        "donor_name": "Sarah Johnson",
        "donor_email": "sarah.j@example.com",
        "donor_phone": "+14155552672",
        "is_anonymous": false
      },
      "expected_response": {
        "success": true,
        "data": {
          "donation_id": "uuid-here",
          "client_secret": "pi_test_xxx_secret_xxx",
          "type": "payment_intent",
          "amount": 50000,
          "amount_display": "$500.00",
          "payment_intent_id": "pi_xxx",
          "stripe_account": "acct_alNoorHouston",
          "created_at": "2026-03-15T13:00:00Z"
        }
      }
    },
    "monthly_subscription": {
      "name": "Monthly Recurring Donation - $25",
      "description": "Recurring donation charged every month",
      "endpoint": "POST /api/mosques/al-noor-houston/donations/create-intent",
      "request": {
        "amount": 2500,
        "donation_type": "monthly",
        "purpose": "general",
        "donor_name": "Ahmed Hassan",
        "donor_email": "ahmed.hassan@example.com",
        "donor_phone": "+14155552673",
        "donor_message": "Supporting this mosque monthly",
        "is_anonymous": false
      },
      "expected_response": {
        "success": true,
        "data": {
          "donation_id": "uuid-here",
          "client_secret": "si_test_xxx_secret_xxx",
          "type": "setup_intent",
          "amount": 2500,
          "amount_display": "$25.00/month",
          "setup_intent_id": "si_xxx",
          "stripe_account": "acct_alNoorHouston",
          "created_at": "2026-03-15T14:00:00Z"
        }
      },
      "note": "For monthly donations, Stripe returns a SetupIntent instead of PaymentIntent"
    },
    "anonymous_donation": {
      "name": "Anonymous Donation - $100",
      "description": "Donation without public name display",
      "endpoint": "POST /api/mosques/al-noor-houston/donations/create-intent",
      "request": {
        "amount": 10000,
        "donation_type": "one_time",
        "purpose": "ramadan",
        "donor_name": "Anonymous Donor",
        "donor_email": "anonymous@example.com",
        "is_anonymous": true
      },
      "expected_response": {
        "success": true,
        "data": {
          "donation_id": "uuid-here",
          "client_secret": "pi_test_xxx_secret_xxx",
          "type": "payment_intent",
          "amount": 10000,
          "amount_display": "$100.00"
        }
      }
    },
    "donation_for_education": {
      "name": "Donation for Education Fund - $250",
      "description": "Specific purpose: Education/Scholarships",
      "endpoint": "POST /api/mosques/al-noor-houston/donations/create-intent",
      "request": {
        "amount": 25000,
        "donation_type": "one_time",
        "purpose": "education",
        "donor_name": "Fatima Ahmed",
        "donor_email": "fatima.ahmed@example.com",
        "donor_message": "For Quran school scholarships",
        "is_anonymous": false
      },
      "expected_response": {
        "success": true,
        "data": {
          "donation_id": "uuid-here",
          "client_secret": "pi_test_xxx_secret_xxx"
        }
      }
    },
    "error_invalid_amount_zero": {
      "name": "ERROR TEST - Invalid Amount (Zero)",
      "description": "Amount must be at least $1 (100 cents)",
      "endpoint": "POST /api/mosques/al-noor-houston/donations/create-intent",
      "request": {
        "amount": 0,
        "donation_type": "one_time",
        "purpose": "general",
        "donor_name": "John Doe",
        "donor_email": "john@example.com"
      },
      "expected_response_status": 400,
      "expected_error": {
        "success": false,
        "error": "Validation failed",
        "messages": ["amount must be greater than or equal to 100"]
      }
    },
    "error_invalid_amount_too_high": {
      "name": "ERROR TEST - Invalid Amount (Too High)",
      "description": "Amount must be max $10,000 (1,000,000 cents)",
      "endpoint": "POST /api/mosques/al-noor-houston/donations/create-intent",
      "request": {
        "amount": 1000001,
        "donation_type": "one_time",
        "purpose": "general",
        "donor_name": "John Doe",
        "donor_email": "john@example.com"
      },
      "expected_response_status": 400,
      "expected_error": {
        "success": false,
        "error": "Validation failed",
        "messages": ["amount must be less than or equal to 1000000"]
      }
    },
    "error_invalid_email": {
      "name": "ERROR TEST - Invalid Email",
      "description": "Email format validation fails",
      "endpoint": "POST /api/mosques/al-noor-houston/donations/create-intent",
      "request": {
        "amount": 1000,
        "donation_type": "one_time",
        "purpose": "general",
        "donor_name": "John Doe",
        "donor_email": "not-an-email",
        "is_anonymous": false
      },
      "expected_response_status": 400,
      "expected_error": {
        "success": false,
        "error": "Validation failed",
        "messages": ["donor_email must be an email"]
      }
    },
    "error_invalid_donation_type": {
      "name": "ERROR TEST - Invalid Donation Type",
      "description": "Must be 'one_time' or 'monthly'",
      "endpoint": "POST /api/mosques/al-noor-houston/donations/create-intent",
      "request": {
        "amount": 1000,
        "donation_type": "quarterly",
        "purpose": "general",
        "donor_name": "John Doe",
        "donor_email": "john@example.com"
      },
      "expected_response_status": 400,
      "expected_error": {
        "success": false,
        "error": "Validation failed",
        "messages": ["donation_type must be one of 'one_time', 'monthly'"]
      }
    },
    "error_missing_required_fields": {
      "name": "ERROR TEST - Missing Required Fields",
      "description": "Amount, donation_type, purpose, donor_name, donor_email are required",
      "endpoint": "POST /api/mosques/al-noor-houston/donations/create-intent",
      "request": {
        "amount": 1000,
        "donation_type": "one_time"
      },
      "expected_response_status": 400,
      "expected_error": {
        "success": false,
        "error": "Validation failed",
        "messages": [
          "purpose is required",
          "donor_name is required",
          "donor_email is required"
        ]
      }
    },
    "error_mosque_not_found": {
      "name": "ERROR TEST - Mosque Not Found",
      "description": "Using non-existent mosque slug",
      "endpoint": "POST /api/mosques/non-existent-mosque/donations/create-intent",
      "request": {
        "amount": 1000,
        "donation_type": "one_time",
        "purpose": "general",
        "donor_name": "John Doe",
        "donor_email": "john@example.com"
      },
      "expected_response_status": 404,
      "expected_error": {
        "success": false,
        "error": "Mosque not found"
      }
    }
  },
