  "test_sequence": {
    "description": "Recommended order to test all donation features",
    "steps": [
      {
        "step": 1,
        "name": "Health Check",
        "what": "Verify API is running",
        "endpoint": "GET http://localhost:4000/",
        "expected": "Hello World!"
      },
      {
        "step": 2,
        "name": "Create Small One-Time Donation",
        "what": "Basic flow - should return client_secret",
        "endpoint": "POST /api/mosques/al-noor-houston/donations/create-intent",
        "request": "Use scenario: 'one_time_donation_small'",
        "expected": "200 OK with client_secret in response"
      },
      {
        "step": 3,
        "name": "Create Monthly Donation",
        "what": "Recurring donation flow",
        "endpoint": "POST /api/mosques/al-noor-houston/donations/create-intent",
        "request": "Use scenario: 'monthly_subscription'",
        "expected": "200 OK with setup_intent (not payment_intent)"
      },
      {
        "step": 4,
        "name": "Test Validation Errors",
        "what": "Verify error handling",
        "tests": [
          "error_invalid_amount_zero",
          "error_invalid_email",
          "error_invalid_donation_type",
          "error_missing_required_fields"
        ],
        "expected": "400 Bad Request with descriptive error messages"
      },
      {
        "step": 5,
        "name": "Test Multiple Mosques",
        "what": "Multi-tenant isolation",
        "endpoints": [
          "POST /api/mosques/al-noor-houston/donations/create-intent",
          "POST /api/mosques/masjid-manhattan/donations/create-intent",
          "POST /api/mosques/masjid-sf/donations/create-intent"
        ],
        "expected": "Each mosque has separate Stripe account in response"
      },
      {
        "step": 6,
        "name": "Admin List Donations",
        "what": "Admin dashboard - requires auth token",
        "endpoint": "GET /api/mosques/al-noor-houston/donations?page=1&limit=25",
        "headers": "Authorization: Bearer <admin_token>",
        "expected": "200 OK with paginated list of mosque donations"
      },
      {
        "step": 7,
        "name": "Admin Summary Metrics",
        "what": "Dashboard KPIs",
        "endpoint": "GET /api/mosques/al-noor-houston/donations/summary",
        "headers": "Authorization: Bearer <admin_token>",
        "expected": "200 OK with MTD total, unique donors, active subscriptions"
      }
    ]
  },
